# ─────────────────────────────────────────────────────────────
#  TxTt — Supabase environment config
#  cp .env.example .env  →  fill in every value  →  never commit .env
# ─────────────────────────────────────────────────────────────

# ── Server URLs ──────────────────────────────────────────────
# Your server's public address (no trailing slash)
API_EXTERNAL_URL=https://api.yourdomain.com

# Your frontend app URL
SITE_URL=https://yourdomain.com

# ── Postgres ─────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change_me_generate_with_openssl

# Generate these with the Supabase JWT tool or:
# node -e "const jwt=require('jsonwebtoken'); console.log(jwt.sign({role:'anon'},process.env.JWT_SECRET,{expiresIn:'100y'}))"
ANON_KEY=your_anon_key_here
SERVICE_ROLE_KEY=your_service_role_key_here

# ── Realtime ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
REALTIME_ENC_KEY=change_me_32_hex_chars
# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=change_me_64_hex_chars

# ── Email / SMTP ─────────────────────────────────────────────
# Use any SMTP — Brevo (free 300/day), Mailgun, Postmark, etc.
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_ADMIN_EMAIL=noreply@yourdomain.com

# ── Twilio (Phone OTP) ───────────────────────────────────────
# Dashboard → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dashboard → Account Info → Auth Token
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Messaging → Services → create one → copy SID
TWILIO_MESSAGE_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google OAuth ─────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: https://api.yourdomain.com/auth/v1/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Apple Sign-In ────────────────────────────────────────────
# developer.apple.com → Certificates → Identifiers → Services IDs
# Return URL: https://api.yourdomain.com/auth/v1/callback
APPLE_CLIENT_ID=com.yourdomain.txtt
# Generated JWT from your Apple private key (.p8 file)
# Use: https://supabase.com/docs/guides/auth/social-login/auth-apple#generate-a-client_secret
APPLE_SECRET=your_apple_generated_jwt
